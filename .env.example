PORT=5000
NODE_ENV=development
MONGO_URI=your_mongodb_connection_string_here
# JWT Secrets
ACCESS_TOKEN_SECRET=your_access_token_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
# Token EXPIRY
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Cloudinary (Lấy từ cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# VNPay Sandbox Credentials
VNP_TMN_CODE=mã_anh_nhận_từ_vnpay
VNP_HASH_SECRET=secret_anh_nhận_từ_vnpay
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:5000/api/payments/vnpay/return
FRONTEND_URL=http://localhost:5173

# Email Service (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="SportBooking Support" <your_email@gmail.com>

# Gemini AI (Lấy từ https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here
